# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ANTHROPIC_API_KEY: Optional. Used for Anthropic AI API calls.
# Users can also configure this via the Settings modal in the app.
ANTHROPIC_API_KEY=

# OPENAI_API_KEY: Optional. Used for OpenAI AI API calls.
# Users can also configure this via the Settings modal in the app.
OPENAI_API_KEY=

# VITE_SENTRY_DSN: Sentry DSN for error monitoring in production.
# Without this, all Sentry.captureException calls silently drop — you won't
# see any errors reported. Get one free at https://sentry.io → Create Project
# → React → copy the DSN.
VITE_SENTRY_DSN=

# VITE_RELEASE: Optional. Release tag for Sentry error grouping. Defaults to
# "memeflow@{package.json.version}". Override for pre-releases, e.g. "0.3.0-rc1".
VITE_RELEASE=

# ============================================================
# 国内化双轨架构 (W1 起加入)
# ============================================================

# VITE_DEPLOYMENT_REGION: "global" (default, 海外版) 或 "cn" (国内版)
# 决定运行时走哪个云栈（Firebase vs 腾讯云）和哪个 AI provider
# (Gemini vs DeepSeek+豆包)。详见 docs/cn-deployment-plan.md
# 海外构建：VITE_DEPLOYMENT_REGION=global npm run build
# 国内构建：VITE_DEPLOYMENT_REGION=cn     npm run build
VITE_DEPLOYMENT_REGION=global

# 以下变量仅在 VITE_DEPLOYMENT_REGION=cn 时使用 ===================

# DeepSeek API key（翻译 / 梗百科 / 笔记 / 语法 / 问答 用）
# 注册：https://platform.deepseek.com → 创建 API Key
DEEPSEEK_API_KEY=

# 豆包/火山引擎 API key（课堂同传段落翻译 用）
# 注册：https://console.volcengine.com/ark → 创建 API Key
DOUBAO_API_KEY=

# 腾讯云 SecretId / SecretKey（后端、ASR、SCF、COS 共用一对）
# 创建：https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# 腾讯云 MongoDB 连接串（云函数 SCF 内部连接用）
TENCENT_MONGODB_URI=

# 短信验证码服务商配置（手机号登录用）
# 推荐用腾讯云 SMS（跟其他腾讯云服务同账号管理最简单）
TENCENT_SMS_APP_ID=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_SIGN_NAME=

# JWT 签名密钥（自建登录用，生产必须长且随机）
JWT_SECRET=
