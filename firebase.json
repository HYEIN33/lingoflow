{
  "firestore": {
    "rules": "firestore.rules",
    "database": "default"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/generate", "function": "apiGenerate" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
