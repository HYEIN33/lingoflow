rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: words
    // Document ID: auto-generated
    // Fields:
    //   - original: string (required) - The original text.
    //   - translation: string (required) - The translated text.
    //   - pronunciation: string (optional) - Phonetic guide.
    //   - examples: list (optional) - Example sentences.
    //   - userId: string (required) - The owner's UID.
    //   - createdAt: timestamp (required) - Creation time.
    //
    // Collection: slangs
    // Document ID: auto-generated
    // Fields:
    //   - term: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: slang_meanings
    // Document ID: auto-generated
    // Fields:
    //   - slangId: string (required)
    //   - meaning: string (required)
    //   - example: string (required)
    //   - authorId: string (required)
    //   - upvotes: number (required)
    //   - status: string (required) - 'approved' or 'rejected'
    //   - createdAt: timestamp (required)
    //
    // Collection: slang_upvotes
    // Document ID: {userId}_{meaningId}
    // Fields:
    //   - userId: string (required)
    //   - meaningId: string (required)
    //   - createdAt: timestamp (required)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin is determined by a custom claim on the auth token OR the
    // user's Firestore profile `role` field. NEVER hardcode emails — if
    // the email account is phished, hardcoding leaks admin to an attacker.
    // Custom claims are set server-side via a Cloud Function using the
    // Admin SDK (which bypasses these rules). The role field is kept as
    // a secondary path so existing admins via Firestore profile still work.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidWord(data) {
      return data.original is string && data.original.size() > 0 && data.original.size() < 500 &&
             data.userId == request.auth.uid &&
             data.usages is list &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidSlang(data) {
      return data.term is string && data.term.size() > 0 && data.term.size() < 100 &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidSlangMeaning(data) {
      return data.slangId is string && data.slangId.size() > 0 &&
             data.meaning is string && data.meaning.size() > 0 && data.meaning.size() < 1000 &&
             data.example is string && data.example.size() < 1000 &&
             data.authorId == request.auth.uid &&
             data.upvotes is number &&
             data.status in ['approved', 'rejected', 'pending'] &&
             (!('voiceName' in data) || data.voiceName in ['Puck', 'Charon', 'Kore', 'Fenrir', 'Zephyr']) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() < 1000)) &&
             (!('mediaType' in data) || data.mediaType in ['image', 'video', 'gif']) &&
             (!('userAudioUrl' in data) || (data.userAudioUrl is string && data.userAudioUrl.size() < 1000)) &&
             (!('authorName' in data) || data.authorName is string) &&
             (!('authorTitle' in data) || data.authorTitle is string) &&
             (!('qualityScore' in data) || data.qualityScore is number) &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidUserProfile(data) {
      return data.userId == request.auth.uid &&
             data.isPro is bool &&
             data.translationCount is number &&
             data.grammarCount is number &&
             data.lastResetDate is string &&
             (!('tabOrder' in data) || data.tabOrder is list) &&
             (!('lastContributionDate' in data) || data.lastContributionDate is string) &&
             (!('currentStreak' in data) || data.currentStreak is number) &&
             (!('hasCompletedOnboarding' in data) || data.hasCompletedOnboarding is bool) &&
             (!('titleLevel1' in data) || data.titleLevel1 is string) &&
             (!('titleLevel2' in data) || data.titleLevel2 is string) &&
             (!('titleLevel3' in data) || data.titleLevel3 is string) &&
             (!('approvedSlangCount' in data) || data.approvedSlangCount is number) &&
             (!('hasUploadedMedia' in data) || data.hasUploadedMedia is bool) &&
             (!('l1PenaltyCount' in data) || data.l1PenaltyCount is number) &&
             (!('l2PenaltyUntil' in data) || data.l2PenaltyUntil is timestamp) &&
             (!('l3PenaltyActive' in data) || data.l3PenaltyActive is bool) &&
             (!('vPenaltyLevel' in data) || data.vPenaltyLevel is number) &&
             (!('reputationScore' in data) || data.reputationScore is number);
    }

    // Fields a user is allowed to mutate on their own profile.
    // Sensitive fields (isPro, reputationScore, penalty fields, approvedSlangCount)
    // can only be written by isAdmin() or by Cloud Functions (admin SDK bypasses rules).
    //
    // displayName + photoURL are user-editable via the UserProfile UI so they
    // show up on the leaderboard and slang meaning cards. 2026-04-13 audit
    // unblocked these — previously UserProfile.tsx was trying to write them
    // but the rule silently rejected, leaving stale data everywhere the
    // leaderboard / profile header read from Firestore.
    function isUserSelfUpdate(before, after) {
      return after.diff(before).affectedKeys().hasOnly([
        'displayName',
        'photoURL',
        'tabOrder',
        'lastContributionDate',
        'currentStreak',
        'hasCompletedOnboarding',
        'translationCount',
        'grammarCount',
        'lastResetDate',
        'titleLevel1',
        'titleLevel2',
        'titleLevel3',
        'hasUploadedMedia',
        'folders',
        'wordFolderMap'
      ]);
    }

    function isValidCounterUpdate(docId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes']) &&
             math.abs(request.resource.data.upvotes - resource.data.upvotes) == 1 &&
             (
               (request.resource.data.upvotes > resource.data.upvotes &&
                !exists(/databases/$(database)/documents/slang_upvotes/$(request.auth.uid + '_' + docId)) &&
                getAfter(/databases/$(database)/documents/slang_upvotes/$(request.auth.uid + '_' + docId)) != null) ||
               (request.resource.data.upvotes < resource.data.upvotes &&
                exists(/databases/$(database)/documents/slang_upvotes/$(request.auth.uid + '_' + docId)) &&
                getAfter(/databases/$(database)/documents/slang_upvotes/$(request.auth.uid + '_' + docId)) == null)
             );
    }

    match /test_connection/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /words/{wordId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidWord(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidWord(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data) && request.resource.data.isPro == false;
      allow update: if isAdmin() || (isOwner(userId) && isUserSelfUpdate(resource.data, request.resource.data));
    }

    match /slangs/{slangId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSlang(request.resource.data);
      // Only admins can mutate or delete shared slang terms — protects the public corpus
      allow update, delete: if isAdmin();
    }

    match /slang_meanings/{meaningId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSlangMeaning(request.resource.data) && request.resource.data.upvotes == 0;
      // Counter (upvote/downvote) updates: anyone authed; full edits: author or admin
      allow update: if isAuthenticated() && (
        isValidCounterUpdate(meaningId) ||
        isAdmin() ||
        (resource.data.authorId == request.auth.uid && isValidSlangMeaning(request.resource.data))
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    match /slang_upvotes/{upvoteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    upvoteId == request.auth.uid + '_' + request.resource.data.meaningId &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.meaningId is string;
      allow delete: if isAuthenticated() && upvoteId.matches('^' + request.auth.uid + '_.*');
    }

    // slang_searches is append-only high-churn data. Rows carry expireAt
    // so the Firestore TTL policy (configured on the `expireAt` field)
    // garbage-collects 7-day-old rows automatically — prevents unbounded
    // growth of this collection and keeps the trending query fast.
    match /slang_searches/{searchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.term is string &&
                    request.resource.data.term.size() > 0 &&
                    request.resource.data.userId == request.auth.uid &&
                    (request.resource.data.createdAt is timestamp || request.resource.data.createdAt == request.time) &&
                    (!('expireAt' in request.resource.data) || request.resource.data.expireAt is timestamp);
    }

    // Comments on slang meanings — anyone authed can read, anyone authed can
    // create their own comment. Author / admin can delete. Text is capped.
    match /slang_comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.authorId == request.auth.uid &&
                    request.resource.data.text is string &&
                    request.resource.data.text.size() > 0 &&
                    request.resource.data.text.size() < 1000 &&
                    request.resource.data.meaningId is string &&
                    request.resource.data.slangId is string &&
                    (request.resource.data.createdAt is timestamp || request.resource.data.createdAt == request.time);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    // Reports on slang meanings — any authed user can create a report on
    // someone else's meaning. Only admins can read/delete (so the public
    // can't see who reported what).
    match /slang_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
                    request.resource.data.reporterId == request.auth.uid &&
                    request.resource.data.meaningId is string &&
                    request.resource.data.reason is string &&
                    request.resource.data.reason.size() < 500 &&
                    (request.resource.data.createdAt is timestamp || request.resource.data.createdAt == request.time);
      allow update, delete: if isAdmin();
    }

    // Translation quality feedback — users rate translations 👍/👎.
    // Only admins can read (analytics). Users can create, not update/delete.
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.keys().hasOnly(['uid', 'query', 'result', 'scene', 'rating', 'reason', 'timestamp']) &&
                    request.resource.data.rating in ['up', 'down'] &&
                    request.resource.data.query is string &&
                    request.resource.data.result is string &&
                    request.resource.data.scene is string &&
                    request.resource.data.scene in ['chat', 'business', 'writing'] &&
                    request.resource.data.reason is string &&
                    request.resource.data.reason.size() <= 500 &&
                    (request.resource.data.timestamp is timestamp || request.resource.data.timestamp == request.time);
      allow update, delete: if false;
    }

    // Translation suggestions — users suggest better translations for quality improvement
    match /translation_suggestions/{suggestionId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.keys().hasOnly(['uid', 'query', 'originalResult', 'suggestion', 'timestamp']) &&
                    request.resource.data.query is string &&
                    request.resource.data.suggestion is string &&
                    request.resource.data.suggestion.size() > 0 &&
                    request.resource.data.suggestion.size() <= 500 &&
                    (request.resource.data.timestamp is timestamp || request.resource.data.timestamp == request.time);
      allow update, delete: if false;
    }
  }
}
